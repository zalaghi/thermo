# Central Thermo web app
THERMO_APP_NAME=Thermo
THERMO_ENV=development
THERMO_DB_PATH=./data/thermo.db
THERMO_ADMIN_USER=admin
THERMO_ADMIN_PASSWORD=change-me-now
THERMO_SECRET_KEY=replace-with-a-long-random-secret
THERMO_POLL_INTERVAL=5
THERMO_PUBLIC_URL=http://YOUR-THERMO-IP:8088
THERMO_PAIRING_TOKEN_TTL_MINUTES=30
THERMO_AGENT_DEFAULT_PORT=8090
THERMO_AGENT_INSTALL_SCRIPT_URL=https://raw.githubusercontent.com/zalaghi/thermo/main/scripts/install-agent.sh
THERMO_AGENT_SOURCE_TARBALL_URL=https://github.com/zalaghi/thermo/archive/refs/heads/main.tar.gz
THERMO_VERIFY_AGENT_ON_COMPLETE=true
TZ=Asia/Tehran

# Thermo agent
THERMO_AGENT_API_KEY=replace-with-a-long-random-agent-secret
THERMO_TEMP_COMMAND="echo 42.5"
THERMO_TEMP_TIMEOUT_SECONDS=3
