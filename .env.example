# Central Thermo web app
THERMO_APP_NAME=Thermo
THERMO_ENV=development
THERMO_DB_PATH=./data/thermo.db
THERMO_ADMIN_USER=admin
THERMO_ADMIN_PASSWORD=change-me-now
THERMO_SECRET_KEY=replace-with-a-long-random-secret
THERMO_POLL_INTERVAL=5
TZ=Asia/Tehran

# Thermo agent
THERMO_AGENT_API_KEY=replace-with-a-long-random-agent-secret
THERMO_TEMP_COMMAND="echo 42.5"
THERMO_TEMP_TIMEOUT_SECONDS=3
